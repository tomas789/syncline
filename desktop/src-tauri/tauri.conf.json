{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Syncline",
  "version": "0.3.0",
  "identifier": "com.syncline.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Syncline",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tomas789/syncline/releases/latest/download/updater.json"
      ],
      "pubkey": "dW5kZWZpbmVk"
    }
  }
}
